{
  "type": "workspace_readwrite",
  "disableTmpWrite": false,
  "enableSharedBuildCache": false,
  "networkPolicy": {
    "default": "deny",
    "allow": [
      "registry.npmjs.org",
      "pypi.org",
      "files.pythonhosted.org",
      "pkg.go.dev",
      "proxy.golang.org",
      "sum.golang.org",
      "crates.io",
      "static.crates.io",
      "index.crates.io",
      "rubygems.org",
      "maven.org",
      "packagist.org",
      "github.com",
      "api.github.com",
      "*.githubusercontent.com"
    ],
    "deny": [
      "*.internal.corp.example.com"
    ]
  }
}
